{
    "workbench.iconTheme": "material-icon-theme",
    "explorer.confirmDelete": false,
    "explorer.compactFolders": false,
    "[javascript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "code-runner.runInTerminal": true,
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "nix.enableLanguageServer": true,
    "nix.serverPath": "nil",
    "nix.serverSettings": {
        "nil": {
            "formatting": {
                "command": [
                    "nixfmt"
                ],
            },
        },
    },
    "code-runner.executorMap": {
        "javascript": "node",
        "java": "cd $dir && javac $fileName && java $fileNameWithoutExt",
        "c": "cd $dir && gcc $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "zig": "zig run",
        "cpp": "cd $dir && g++ $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "objective-c": "cd $dir && gcc -framework Cocoa $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "php": "php",
        "python": "python -u",
        "perl": "perl",
        "perl6": "perl6",
        "ruby": "ruby",
        "go": "go run",
        "lua": "lua",
        "groovy": "groovy",
        "powershell": "powershell -ExecutionPolicy ByPass -File",
        "bat": "cmd /c",
        "shellscript": "bash",
        "fsharp": "fsi",
        "csharp": "dotnet run",
        "vbscript": "cscript //Nologo",
        "typescript": "ts-node $fileName 2> /dev/null || deno run $fileName",
        "coffeescript": "coffee",
        "scala": "scala",
        "swift": "swift",
        "julia": "julia",
        "crystal": "crystal",
        "ocaml": "ocaml",
        "r": "Rscript",
        "applescript": "osascript",
        "clojure": "lein exec",
        "haxe": "haxe --cwd $dirWithoutTrailingSlash --run $fileNameWithoutExt",
        "rust": "cd $dir && rustc $fileName && $dir$fileNameWithoutExt",
        "racket": "racket",
        "scheme": "csi -script",
        "ahk": "autohotkey",
        "autoit": "autoit3",
        "dart": "dart",
        "pascal": "cd $dir && fpc $fileName && $dir$fileNameWithoutExt",
        "d": "cd $dir && dmd $fileName && $dir$fileNameWithoutExt",
        "haskell": "runghc",
        "nim": "nim compile --verbosity:0 --hints:off --run",
        "lisp": "sbcl --script",
        "kit": "kitc --run",
        "v": "v run",
        "sass": "sass --style expanded",
        "scss": "scss --style expanded",
        "less": "cd $dir && lessc $fileName $fileNameWithoutExt.css",
        "FortranFreeForm": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran-modern": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran_fixed-form": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "fortran": "cd $dir && gfortran $fileName -o $fileNameWithoutExt && $dir$fileNameWithoutExt",
        "sml": "cd $dir && sml $fileName",
        "mojo": "mojo run",
        "erlang": "escript",
        "spwn": "spwn build",
        "pkl": "cd $dir && pkl eval -f yaml $fileName -o $fileNameWithoutExt.yaml",
        "gleam": "gleam run -m $fileNameWithoutExt",
    },
    "editor.inlayHints.enabled": "offUnlessPressed",
    "[json]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "cpplint.cpplintPath": ".devenv/profile/bin/cpplint",
    "python.analysis.typeCheckingMode": "strict",
    "github.copilot.chat.codesearch.enabled": true,
    "chat.agent.enabled": true,
    "LaravelExtraIntellisense.phpCommand": ".devenv/profile/bin/php -r \"{code}\"",
    "[php]": {
        "editor.defaultFormatter": "bmewburn.vscode-intelephense-client",
    },
    "editor.fontFamily": "'Noto Sans Mono','DejaVu Sans Mono','Droid Sans Mono', monospace",
    "github.copilot.nextEditSuggestions.enabled": true,
    "chat.instructionsFilesLocations": {
        ".github/instructions": true,
    },
    "redhat.telemetry.enabled": false,
    "[dockercompose]": {
        "editor.insertSpaces": true,
        "editor.tabSize": 2,
        "editor.autoIndent": "advanced",
        "editor.defaultFormatter": "redhat.vscode-yaml",
    },
    "[github-actions-workflow]": {
        "editor.defaultFormatter": "redhat.vscode-yaml",
    },
    "chat.tools.terminal.autoApprove": {
        "terraflake": true,
    },
    "chat.viewSessions.orientation": "stacked",
    "gitlens.ai.model": "vscode",
    "gitlens.ai.vscode.model": "copilot:gpt-4.1",
    "[html]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "workbench.colorTheme": "Dark+",
    "chat.tools.urls.autoApprove": {
        "https://code.visualstudio.com": true,
        "https://github.com/microsoft/vscode/wiki/*": true,
        "https://spatie.be/docs/laravel-data/v4/introduction": {
            "approveRequest": true,
            "approveResponse": false
        },
        "https://spatie.be": {
            "approveRequest": false,
            "approveResponse": true
        },
        "https://larazeus.com": true,
        "https://github.com": true,
        "https://raw.githubusercontent.com": {
            "approveResponse": true
        },
        "https://api.github.com": {
            "approveRequest": false,
            "approveResponse": true
        },
        "https://jsr.io/@fresh/plugin-vite/1.0.8/src/plugin.ts": {
            "approveRequest": true,
            "approveResponse": false
        },
        "https://jsr.io": true,
        "https://gleam-time.hexdocs.pm": true,
        "https://docs.hercules-ci.com/arion": true,
        "https://tailwindcss.com": true,
        "https://marketplace.visualstudio.com/items": true,
        "https://marketplace.visualstudio.com": true,
        "https://github.com/zokugun/vscode-sync-settings": true,
        "https://github.com/zokugun": true,
        "https://nix-community.github.io": {
            "approveRequest": true,
            "approveResponse": false
        },
        "https://raw.githubusercontent.com/flightlessmango/MangoHud/master/src/config.cpp": true,
        "https://raw.githubusercontent.com/flightlessmango/MangoHud/master/src": true,
        "https://raw.githubusercontent.com/flightlessmango/MangoHud/master": true,
        "https://raw.githubusercontent.com/flightlessmango/MangoHud": true,
        "https://raw.githubusercontent.com/flightlessmango": true,
        "https://*.githubusercontent.com": true,
        "https://search.nixos.org": true
    },
    "[gdscript]": {
        "editor.defaultFormatter": "geequlim.godot-tools",
    },
    "terminal.integrated.commandsToSkipShell": [
        "language-julia.interrupt"
    ],
    "julia.symbolCacheDownload": true,
    "julia.enableCrashReporter": false,
    "julia.juliaup.install.hint": false,
    "chat.disableAIFeatures": false,
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features",
    },
    "syncSettings.resources": [
        "extensions",
        "keybindings",
        "settings",
        "snippets",
        "tasks",
        "uiState"
    ],
    "syncSettings.confirmSync": false,
    "syncSettings.crons": {
        "review": "0 * * * *",
        "upload": "*/5 * * * *"
    },
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false
    },
    "yaml.disableSchemaDetection": [
        "**/.github/workflows/*.yml",
        "**/.github/workflows/*.yaml",
        "**/.gitea/workflows/*.yml",
        "**/.gitea/workflows/*.yaml",
        "**/.forgejo/workflows/*.yml",
        "**/.forgejo/workflows/*.yaml"
    ],
    "security.workspace.trust.untrustedFiles": "open",
}